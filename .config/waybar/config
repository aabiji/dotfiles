{
    "layer": "top",
    "position": "top",
    "height": 16,
    "modules-left": [
        "hyprland/workspaces",
        "hyprland/window"
    ],
    "modules-center": [],
    "modules-right": [
        "backlight",
        "pulseaudio",
        "battery",
        "custom/time",
        "tray"
    ],

    "hyprland/workspaces": {
        "format": "{name}",
        "sort-by-number": true,
        "on-click": "activate"
    },
    "hyprland/window": {
        "max-length": 150
    },
    "tray": {
        "icon-size": 18,
        "spacing": 15
    },
    "custom/time": {
        "exec": "date '+%I:%M'",
        "format": "{}  ",
        "interval": 1,
        "tootip": true
    },
    "battery": {
        "bat": "BAT1",
        "states": {
            "full": 99,
            "good": 98,
            "normal": 98,
            "warning": 20,
            "critical": 20
        },
        "format": "{icon}   {capacity}%",
        "format-good": "{icon}   {capacity}%",
        "format-full": "   {capacity}%",
        "format-icons": [
            "",
            "",
            "",
            "",
            ""
        ],
        "interval": 30
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "☼ {percent}%  ",
        "interval": 60
    },
    "pulseaudio": {
        "format": "{icon}  {volume}%  ",
        "format-bluetooth": "  {volume}%  ",
        "format-muted": "婢  Mute  ",
        "interval": 60,
        "format-icons": {
            "default": [
                ""
            ]
        },
        "on-click": "blueman-manager"
    }
}
