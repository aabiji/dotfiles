{
  "telemetry": {
    "metrics": false,
    "diagnostics": false
  },
  "indent_guides": {
    "enabled": false
  },
  "ui_font_size": 16,
  "buffer_font_size": 12,
  "extend_comment_on_newline": false,
  "buffer_font_family": "JetBrains Mono",
  "buffer_line_height": "standard",
  "gutter": { "folds": false },
