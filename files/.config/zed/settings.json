{
  "project_panel": {
    "dock": "left",
  },
  "title_bar": {
    "button_layout": "platform_default",
    "show_onboarding_banner": false,
    "show_user_picture": false,
    "show_sign_in": false,
  },
  "disable_ai": true,
  "current_line_highlight": "gutter",
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "scrollbar": {
    "show": "never",
    "diagnostics": "none",
    "cursors": true,
    "search_results": true,
    "git_diff": false,
  },
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  "toolbar": {
    "quick_actions": false,
    "breadcrumbs": false,
  },
  "minimap": {
    "thumb": "hover",
    "show": "always",
  },
  "scroll_beyond_last_line": "off",
  "buffer_line_height": "standard",
  "buffer_font_family": "JetBrains Mono",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "vim_mode": true,
  "ui_font_size": 16,
  "buffer_font_size": 13.0,
  "theme": {
    "mode": "system",
    "light": "Solarized Light",
    "dark": "0x96f Theme",
  },
  "theme_overrides": {
    "Base16 OceanicNext": {
      "syntax": {
        "variable": {
          "color": "#C0C5CE",
        },
      },
    },
  },
  "languages": {
    "C++": {
      "format_on_save": "on",
      "tab_size": 2,
      "hard_tabs": false,
    },
    "C": {
      "format_on_save": "on",
    },
  },
}
